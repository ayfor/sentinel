{
  "name": "sentinel",
  "private": true,
  "version": "0.1.0",
  "description": "Map-based real-time data visualization — patrol drone, restricted zones, live telemetry",
  "workspaces": ["shared", "server", "client"],
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,white \"npm:dev -w server\" \"npm:dev -w client\"",
    "build": "npm run build -w client",
    "test": "npm run test -w server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.0"
  }
}
